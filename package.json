{
  "name": "agent-tracer",
  "version": "0.2.3",
  "description": "Live trace viewer for Claude Code agent execution — shows subagent tree, tool calls, tokens, and cost in real time",
  "main": "bin/agent-tracer-daemon.js",
  "bin": {
    "agent-tracer-daemon": "bin/agent-tracer-daemon.js"
  },
  "scripts": {
    "start": "node bin/agent-tracer-daemon.js",
    "daemon": "node bin/agent-tracer-daemon.js",
    "install-hooks": "node bin/agent-tracer-daemon.js --install",
    "test": "vitest run --reporter=verbose"
  },
  "files": [
    "bin/agent-tracer-daemon.js",
    "lib",
    "public",
    "README.md"
  ],
  "keywords": [
    "claude",
    "claude-code",
    "agent",
    "trace",
    "subagent",
    "observability",
    "hooks"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/hashika-kalisetty/agent-tracer.git"
  },
  "homepage": "https://github.com/hashika-kalisetty/agent-tracer#readme",
  "bugs": {
    "url": "https://github.com/hashika-kalisetty/agent-tracer/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.3",
    "vitest": "^4.1.2"
  }
}
